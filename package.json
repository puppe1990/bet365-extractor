{
  "name": "bet365-extractor",
  "version": "3.10.7",
  "type": "module",
  "scripts": {
    "test": "node --test tests/**/*.test.js",
    "build": "node scripts/build-console.mjs && node scripts/build-html.mjs && node scripts/build-extension.mjs",
    "build:html": "node scripts/build-html.mjs",
    "build:extension": "node scripts/build-extension.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.4"
  }
}
