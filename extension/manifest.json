{
  "manifest_version": 3,
  "name": "Bet365 Data Extractor",
  "description": "Extrai match, stats e odds da Bet365 e baixa em ZIP",
  "version": "3.10.2",
  "permissions": ["activeTab", "downloads", "scripting"],
  "host_permissions": [
    "*://*.bet365.bet.br/*",
    "*://*.bet365.com/*",
    "*://*.bet365.bet/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Bet365 Extractor",
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.bet365.bet.br/*",
        "*://*.bet365.com/*",
        "*://*.bet365.bet/*"
      ],
      "js": ["dist/content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}